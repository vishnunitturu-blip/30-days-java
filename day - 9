2. Pyramid Pattern (Important)
Output
   *
  * *
 * * *
* * * *
Example 1
for(int i = 1; i <= 4; i++){
    for(int space = 1; space <= 4 - i; space++){
        System.out.print(" ");
    }
    for(int j = 1; j <= i; j++){
        System.out.print("* ");
    }
    System.out.println();
}
Example 2 (Reverse Pyramid)
* * * *
 * * *
  * *
   *
for(int i = 4; i >= 1; i--){
    for(int space = 1; space <= 4 - i; space++){
        System.out.print(" ");
    }
    for(int j = 1; j <= i; j++){
        System.out.print("* ");
    }
    System.out.println();
}
